# === Images — core services ===
CACTUS_ORCHESTRATOR_IMAGE="cactusimageregistry.azurecr.io/cactus-orchestrator:podman"
CACTUS_UI_IMAGE="cactusimageregistry.azurecr.io/cactus-ui:podman"
CACTUS_CLIENT_NOTIFICATIONS_IMAGE="cactusimageregistry.azurecr.io/cactus-client-notifications:podman"

# === Images - pod services for CSIP Aus Versions
CACTUS_IMAGE__V1_2__CSIP_AUS_VERSION="v1.2"
CACTUS_IMAGE__V1_2__POSTGRES="docker.io/library/postgres:15"
CACTUS_IMAGE__V1_2__RABBITMQ="docker.io/library/rabbitmq:3"
CACTUS_IMAGE__V1_2__INIT="cactusimageregistry.azurecr.io/cactus-teststack-init:158-v12"
CACTUS_IMAGE__V1_2__ENVOY="cactusimageregistry.azurecr.io/cactus-envoy:158-v12"
CACTUS_IMAGE__V1_2__RUNNER="cactusimageregistry.azurecr.io/cactus-runner:158-v12"

CACTUS_IMAGE__V1_3__CSIP_AUS_VERSION="v1.3"
CACTUS_IMAGE__V1_3__POSTGRES="docker.io/library/postgres:15"
CACTUS_IMAGE__V1_3__RABBITMQ="docker.io/library/rabbitmq:3"
CACTUS_IMAGE__V1_3__INIT="cactusimageregistry.azurecr.io/cactus-teststack-init:158-v13"
CACTUS_IMAGE__V1_3__ENVOY="cactusimageregistry.azurecr.io/cactus-envoy:158-v13"
CACTUS_IMAGE__V1_3__RUNNER="cactusimageregistry.azurecr.io/cactus-runner:158-v13"

CACTUS_IMAGE__V1_3_STORAGE__CSIP_AUS_VERSION="v1.3-beta/storage"
CACTUS_IMAGE__V1_3_STORAGE__POSTGRES="docker.io/library/postgres:15"
CACTUS_IMAGE__V1_3_STORAGE__RABBITMQ="docker.io/library/rabbitmq:3"
CACTUS_IMAGE__V1_3_STORAGE__INIT="cactusimageregistry.azurecr.io/cactus-teststack-init:158-v13-storage-beta"
CACTUS_IMAGE__V1_3_STORAGE__ENVOY="cactusimageregistry.azurecr.io/cactus-envoy:158-v13-storage-beta"
CACTUS_IMAGE__V1_3_STORAGE__RUNNER="cactusimageregistry.azurecr.io/cactus-runner:158-v13-storage-beta"


# === Domains ===
CACTUS_FQDN="cactus.example.com"
CACTUS_CLIENT_NOTIFICATIONS_MOUNT_POINT="/client-notifications/"
ENVOY_PREFIX="/envoy"

# === JWT Auth (cactus-orchestrator) ===
JWTAUTH_JWKS_URL="https://example.com/.well-known/jwks.json"
JWTAUTH_AUDIENCE="https://cactus.example.com/"
JWTAUTH_ISSUER="https://example.com/"
IGNORED_CSIP_AUS_VERSIONS="[]"

# === Database ===
# Python asyncpg connection string for the orchestrator's external postgres instance.
ORCHESTRATOR_DATABASE_URL="postgresql+asyncpg://cactususer:password@db.example.com:5432/cactusorchestrator"

# === Podman ===
PODMAN_SOCKET="/run/podman/podman.sock"
PODMAN_NETWORK="cactus-net"
PODMAN_RUNNER_PORT="8080"

# === Certificates (host file paths; mounted read-only into the orchestrator container) ===
# These are the PKI artefacts from ../pki/create-cert.sh. The orchestrator loads the SERCA trust
# anchor, the device + aggregator signing chains (MICA/ICA keys, to issue leaf client certs), and the
# utility-server (envoy / DNSP) chain. The envoy EE cert+key is the notification mTLS identity envoy
# presents (and the orchestrator stages it + SERCA into each test pod). Names map 1:1 to
# CactusOrchestratorSettings; missing envoy EE paths => pod creation fails (notification mTLS is required).
CERT_SERCA_PATH="/etc/cactus/pki/serca.cert.pem"

# Device signing chain (./create-cert.sh device ...): SERCA -> MCA -> MICA -> device EE.
CERT_DEVICE_MCA_PATH="/etc/cactus/pki/cactus-chain/mca.cert.pem"
CERT_DEVICE_MICA_CRT_PATH="/etc/cactus/pki/cactus-chain/mica.cert.pem"
CERT_DEVICE_MICA_KEY_PATH="/etc/cactus/pki/cactus-chain/mica.key.pem"

# Aggregator signing chain (./create-cert.sh aggregator ...): SERCA -> Services PCA -> Agg ICA -> agg EE.
CERT_AGG_PCA_PATH="/etc/cactus/pki/aggregator-chain/pca.cert.pem"
CERT_AGG_ICA_CRT_PATH="/etc/cactus/pki/aggregator-chain/ica.cert.pem"
CERT_AGG_ICA_KEY_PATH="/etc/cactus/pki/aggregator-chain/ica.key.pem"

# Utility-server (envoy / DNSP) chain (./create-cert.sh dnsp ...): SERCA -> Services PCA -> DNSP ICA -> envoy EE.
# The EE is a fixed wildcard cert; the orchestrator presents/stages it for notification mTLS and serves the
# PCA/ICA in the GET /certificate/authority bundle. PCA/ICA here are public certs only (no keys needed).
CERT_ENVOY_PCA_PATH="/etc/cactus/pki/dnsp-chain/pca.cert.pem"
CERT_ENVOY_ICA_PATH="/etc/cactus/pki/dnsp-chain/ica.cert.pem"
CERT_ENVOY_EE_CRT_PATH="/etc/cactus/pki/dnsp-ee/envoy.cert.pem"
CERT_ENVOY_EE_KEY_PATH="/etc/cactus/pki/dnsp-ee/envoy.key.pem"

# Public-facing utility-server TLS for nginx (NOT an orchestrator setting; consumed by nginx-config.sh).
CERT_SERVER_CERT_FULLCHAIN_PATH="/etc/cactus/pki/server/server.fullchain.pem"
CERT_SERVER_KEY_PATH="/etc/cactus/pki/server/server.key.pem"

# === cactus-ui ===
# Orchestrator is reachable by container name on cactus-net (no k8s DNS needed).
CACTUS_ORCHESTRATOR_BASEURL="http://cactus-orchestrator:8080"
CACTUS_ORCHESTRATOR_AUDIENCE="https://cactus.example.com/"
CACTUS_PLATFORM_VERSION="v0.0.0-beta.1"
CACTUS_PLATFORM_SUPPORT_EMAIL="support@example.com"
BANNER_MESSAGE=""
LOGIN_BANNER_MESSAGE=""
# OAuth2 credentials (Auth0 or equivalent)
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_DOMAIN=""
APP_SECRET_KEY=""

# === cactus-client-notifications ===
CACTUS_CLIENT_NOTIFICATIONS_SERVER_URL="https://cactus.example.com/"
