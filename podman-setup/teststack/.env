# Copy to .env and fill in image tags before running docker-compose.
# Image tags should match what's in ../../docker/versions.lock.

CACTUS_ENVOY_APP_IMAGE=cactusimageregistry.azurecr.io/cactus-envoy:153-v12
CACTUS_TESTSTACK_INIT_IMAGE=cactusimageregistry.azurecr.io/cactus-teststack-init:153-v12
CACTUS_RUNNER_IMAGE=cactusimageregistry.azurecr.io/cactus-runner:153-v12
CACTUS_ENVOY_DB_IMAGE=docker.io/library/postgres:15

# CSIP-Aus version passed to the runner (drives content-type negotiation).
CSIP_AUS_VERSION=1.2
