# === Images — core services ===
CACTUS_ORCHESTRATOR_IMAGE="cactusimageregistry.azurecr.io/cactus-orchestrator:40"
CACTUS_UI_IMAGE="cactusimageregistry.azurecr.io/cactus-ui:40"
CACTUS_CLIENT_NOTIFICATIONS_IMAGE="cactusimageregistry.azurecr.io/cactus-client-notifications:40"

# === Domains ===
TEST_EXECUTION_FQDN="envoy.example.com"
TEST_ORCHESTRATION_FQDN="cactus.example.com"
CACTUS_CLIENT_NOTIFICATIONS_FQDN="cactus.example.com"
CACTUS_CLIENT_NOTIFICATIONS_MOUNT_POINT="/client-notifications/"

# === JWT Auth (cactus-orchestrator) ===
JWTAUTH_JWKS_URL="https://example.com/.well-known/jwks.json"
JWTAUTH_AUDIENCE="https://cactus.example.com/"
JWTAUTH_ISSUER="https://example.com/"
IGNORED_CSIP_AUS_VERSIONS="[]"

# === Database ===
# Python asyncpg connection string for the orchestrator's external postgres instance.
ORCHESTRATOR_DATABASE_URL="postgresql+asyncpg://cactususer:password@db.example.com:5432/cactusorchestrator"

# === Podman ===
PODMAN_SOCKET="/run/podman/podman.sock"
PODMAN_NETWORK="cactus-net"
PODMAN_RUNNER_PORT="8080"
# JSON map: csip_aus_version → {service: image}.  Add an entry per supported CSIP-Aus version.
PODMAN_TESTSTACK_IMAGES='{"1.3": {"postgres": "postgres:15", "pubsub": "rabbitmq:3", "teststack-init": "cactusimageregistry.azurecr.io/cactus-teststack-init:40-v13", "envoy": "cactusimageregistry.azurecr.io/cactus-envoy:40-v13", "taskiq-worker": "cactusimageregistry.azurecr.io/cactus-envoy:40-v13", "runner": "cactusimageregistry.azurecr.io/cactus-runner:40-v13"}}'

# === Certificates (host file paths; mounted read-only into the orchestrator container) ===
# These are the PKI artefacts from ../pki/create-cert.sh (the cactus-chain outputs).
CERT_SERCA_PATH="/etc/cactus/pki/serca.cert.pem"
CERT_MCA_PATH="/etc/cactus/pki/cactus-chain/mca.cert.pem"
CERT_MICA_CRT_PATH="/etc/cactus/pki/cactus-chain/mica.cert.pem"
CERT_MICA_KEY_PATH="/etc/cactus/pki/cactus-chain/mica.key.pem"

# === cactus-ui ===
# Orchestrator is reachable by container name on cactus-net (no k8s DNS needed).
CACTUS_ORCHESTRATOR_BASEURL="http://cactus-orchestrator:8080"
CACTUS_ORCHESTRATOR_AUDIENCE="https://cactus.example.com/"
CACTUS_PLATFORM_VERSION="v0.0.0-beta.1"
CACTUS_PLATFORM_SUPPORT_EMAIL="support@example.com"
BANNER_MESSAGE=""
LOGIN_BANNER_MESSAGE=""
# OAuth2 credentials (Auth0 or equivalent)
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_DOMAIN=""
APP_SECRET_KEY=""

# === cactus-client-notifications ===
CACTUS_CLIENT_NOTIFICATIONS_SERVER_URL="https://cactus.example.com/"
